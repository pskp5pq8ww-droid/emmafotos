NODE_ENV=production

# URL pública del sitio (sin barra final)
NEXT_PUBLIC_SITE_URL=https://emmafotos.com

# Orígenes permitidos para Server Actions detrás del proxy de Hostinger.
# Pon el dominio real (con y sin www si aplica).
ALLOWED_ORIGINS=emmafotos.com,www.emmafotos.com

# Ruta absoluta al directorio de uploads en el servidor.
# En Hostinger: /home/u613502604/storage
UPLOAD_DIR=/home/u613502604/storage

# Clave secreta para firmar sesiones de galería (OBLIGATORIO en producción).
# Genera una con: openssl rand -hex 32
GALLERY_SESSION_SECRET=

# SMTP para emails de contacto y notificación de galería (opcional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Emmanuel Rojas Studio <no-reply@emmafotos.com>"
CONTACT_TO=hola@emmafotos.com

# API key del agente IA del admin (Anthropic). Sin esto el asistente
# muestra un mensaje de "no configurado" — el resto del sitio no se afecta.
AGENT_API_KEY=
